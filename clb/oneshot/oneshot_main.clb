{"type":"Microchip CLB Synthesizer Design","version":"2.0","name":"oneshot_test","projectId":"608d4b87-5c05-4b5f-b00c-21d6324d0587","creationDate":"2026-01-26T17:56:01.639Z","backendversion":"https://logic.microchip.com/","device":"PIC16F13145","documentModels":[{"type":1,"id":"0ddc37d4-71b1-4c94-b484-addfbad0c9a8","name":"oneshot","text":"/*\nMicrochip CLB Synthesizer - new Verilog file\n\nImplement your Verilog module in this file and use it elsewhere in your CLB design.\n\n// Example 1: combinatorial AND implementation:\nmodule oneshot (a, b, q);\n    input a, b;\n    output q;\n    assign q = a & b;\nendmodule\n\n// Example 2: clocked one-bit counter that toggles only when enabled\nmodule oneshot (CLK, enable, q);\n    input CLK;\n    input enable;\n    output reg q;\n    always @(posedge CLK) begin\n        if (enable) begin\n            q <= !q;\n        end\n    end\nendmodule\n\nTips for using Verilog in the CLB Synthesizer:\n  - SystemVerilog and VHDL are not supported; use Verilog-2005 only.\n  - The CLB has a single global clock which is the 'CLK' port in all Verilog modules.\n  - It is not possible to use 'always @' constructs other than 'always @(posedge CLK)'.\n*/\n\n  \nmodule oneshot(CLK, d, q);\n   input CLK;\n// \"The CLB has a single global clock, the ‘CLK’ port, in all Verilog modules.\"\n   input d;\n   output q;\n\n   logic  nq1, jk, q2;\n   \n   // the AND gate of d with the inverse of its FF #1 snapshot...\n   assign jk = nq1 & d;\n   always @(posedge CLK)\n     begin\n\tnq1 <= ~d;\n     end\n\n   // ...determines whether to invert the initial state in FF #2\n   assign q = q2;\n   always @(posedge CLK)\n     begin\n\tif (jk)\n\t  begin\n\t     q2 <= ~q2;\n\t  end\n     end\nendmodule // oneshot\n"},{"type":0,"id":"a8435158-d117-4c9e-9766-53a862ac0ef1","name":"main","data":{"class":"GraphLinksModel","linkKeyProperty":"key","linkFromPortIdProperty":"fromPort","linkToPortIdProperty":"toPort","nodeDataArray":[{"category":"inputport","portname":"CLBIN0PPS","size":"130 20","loc":"-690 -150","key":1,"settings":{"inputmodifier":"sync"}},{"category":"outputport","portname":"PPS_OUT0","size":"130 20","loc":"-190 -150","key":2,"settings":{}},{"key":-3,"category":"sheet","refdes":"","loc":"-580 -180","name":"oneshot","inputs":[{"portId":"d","label":"d","settings":{}}],"outputs":[{"portId":"q","label":"q","settings":{}}],"globalinputs":[{"portId":"CLK","label":"CLK","settings":{}}],"globaloutputs":[]}],"linkDataArray":[{"from":1,"to":-3,"fromPort":"OUT","toPort":"d","key":-1,"points":[-625,-150,-615,-150,-602.5,-150,-602.5,-150,-590,-150,-580,-150]},{"from":-3,"to":2,"fromPort":"q","toPort":"IN","key":-2,"points":[-340,-150,-330,-150,-297.5,-150,-297.5,-150,-265,-150,-255,-150]}]},"properties":{}}],"entryFile":"main","settings":[]}