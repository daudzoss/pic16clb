{"type":"Microchip CLB Synthesizer Design","version":"2.0","name":"failed_to_route_xnors_safety_wrapper","projectId":"5b7d7e83-23e3-4672-8848-b866c51dbec5","creationDate":"2026-03-18T13:32:01.095Z","backendversion":"https://logic.microchip.com/","device":"PIC16F13256","documentModels":[{"type":1,"id":"2a7e846f-2304-4e85-944f-9e6b57f8cabc","name":"charging","text":"\nmodule charging(absent,timeout,tx7,tx6,tx5,tx4,tx3,tx2,tx1,tx0,rx7,rx6,rx5,rx4,rx3,rx2,rx1,rx0,confirm);\n input absent,timeout;\n input tx7,tx6,tx5,tx4,tx3,tx2,tx1,tx0;\n input rx7,rx6,rx5,rx4,rx3,rx2,rx1,rx0;\n output confirm;\n\n wire [7:0] txchar, rxchar;\n assign txchar = {tx7,tx6,tx5,tx4,tx3,tx2,tx1,tx0};\n assign rxchar = {rx7,rx6,rx5,rx4,rx3,rx2,rx1,rx0};\n assign confirm = (~absent) & (~timeout) & (txchar == rxchar);\nendmodule\n"},{"type":1,"id":"32de02d6-1bb0-4ae5-9f2e-c77bc8fe4218","name":"documentation","text":"/*\nMicrochip CLB Synthesizer - new Verilog file\n\nImplement your Verilog module in this file and use it elsewhere in your CLB design.\n\n// Example 1: combinatorial AND implementation:\nmodule documentation (a, b, q);\n    input a, b;\n    output q;\n    assign q = a & b;\nendmodule\n\n// Example 2: clocked one-bit counter that toggles only when enabled\nmodule documentation (CLK, enable, q);\n    input CLK;\n    input enable;\n    output reg q;\n    always @(posedge CLK) begin\n        if (enable) begin\n            q <= !q;\n        end\n    end\nendmodule\n\nTips for using Verilog in the CLB Synthesizer:\n  - SystemVerilog and VHDL are not supported; use Verilog-2005 only.\n  - The CLB has a single global clock which is the 'CLK' port in all Verilog modules.\n  - It is not possible to use 'always @' constructs other than 'always @(posedge CLK)'.\n*/\n\nmodule documentation();\nendmodule\n"},{"type":1,"id":"bd493cdf-50e2-41ba-83dc-f7fee039f204","name":"safety_wrapper","text":"module safety_wrapper(CLK,\n                      nsleep,sw2,sw1,on_charger,dir,winding,\n                      tmr1ovfl,tmr2ovfl,tmr3ovfl,tmr4ovfl,\n                      tmr1clk,tmr1gate,tmr2clk,tmr2rst,tmr3clk,tmr3gate,tmr4clk,tmr4rst,\n                      out5v_nenable);\n input CLK;\n input nsleep,sw2,sw1,on_charger,dir,winding;\n input tmr1ovfl,tmr2ovfl,tmr3ovfl,tmr4ovfl;\n output tmr1clk,tmr1gate,tmr2clk,tmr2rst,tmr3clk,tmr3gate,tmr4clk,tmr4rst;\n output out5v_nenable;\n\n // dummy assignments for now so that ports don't get optimized away\n assign tmr1clk = sw2;\n assign tmr1gate = sw1;\n assign tmr2clk = on_charger;\n assign tmr2rst = dir;\n assign tmr3clk = winding;\n assign tmr3gate = tmr1ovfl;\n assign tmr4clk = tmr2ovfl;\n assign tmr4rst = tmr3ovfl;\n\n always @(posedge CLK)\n  begin\n   out5v_nenable = tmr4ovfl | nsleep;\n  end\nendmodule\n"},{"type":0,"id":"9ef149bf-2feb-4195-a853-b1bbfaea254d","name":"main","data":{"class":"GraphLinksModel","linkKeyProperty":"key","linkFromPortIdProperty":"fromPort","linkToPortIdProperty":"toPort","nodeDataArray":[{"category":"inputport","portname":"CLBSWIN24","size":"130 20","loc":"-330 30","key":1,"settings":{}},{"category":"inputport","portname":"CLBSWIN31","size":"130 20","loc":"-330 -110","key":2,"settings":{}},{"category":"inputport","portname":"CLBSWIN30","size":"130 20","loc":"-330 -90","key":3,"settings":{}},{"category":"inputport","portname":"CLBSWIN29","size":"130 20","loc":"-330 -70","key":4,"settings":{}},{"category":"inputport","portname":"CLBSWIN28","size":"130 20","loc":"-330 -50","key":5,"settings":{}},{"category":"inputport","portname":"CLBSWIN27","size":"130 20","loc":"-330 -30","key":6,"settings":{}},{"category":"inputport","portname":"CLBSWIN26","size":"130 20","loc":"-330 -10","key":7,"settings":{}},{"category":"inputport","portname":"CLBSWIN25","size":"130 20","loc":"-330 10","key":8,"settings":{}},{"category":"inputport","portname":"CLBSWIN8","size":"130 20","loc":"-330 -290","key":9,"settings":{}},{"category":"inputport","portname":"CLBSWIN9","size":"130 20","loc":"-330 -310","key":10,"settings