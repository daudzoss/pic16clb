{"type":"Microchip CLB Synthesizer Design","version":"2.0","name":"routed_93percent_ble","projectId":"5b7d7e83-23e3-4672-8848-b866c51dbec5","creationDate":"2026-03-18T13:32:01.095Z","backendversion":"https://logic.microchip.com/","device":"PIC16F13256","documentModels":[{"type":1,"id":"bd493cdf-50e2-41ba-83dc-f7fee039f204","name":"safety_wrapper","text":"module safety_wrapper(CLK,\n                      nsleep,sw2,sw1,on_charger,dir,winding,\n                      tmr1ovfl,tmr2ovfl,tmr3ovfl,tmr4ovfl,\n                      tmr1clk,tmr1gate,tmr2clk,tmr2rst,tmr3clk,tmr3gate,tmr4clk,tmr4rst,\n                      out5v_nenable);\n input CLK;\n input nsleep,sw2,sw1,on_charger,dir,winding;\n input tmr1ovfl,tmr2ovfl,tmr3ovfl,tmr4ovfl;\n output tmr1clk,tmr1gate,tmr2clk,tmr2rst,tmr3clk,tmr3gate,tmr4clk,tmr4rst;\n output out5v_nenable;\n\n // dummy assignments for now so that ports don't get optimized away\n assign tmr1clk = sw2;\n assign tmr1gate = sw1;\n assign tmr2clk = on_charger;\n assign tmr2rst = dir;\n assign tmr3clk = winding;\n assign tmr3gate = tmr1ovfl;\n assign tmr4clk = tmr2ovfl;\n assign tmr4rst = tmr3ovfl;\n\n always @(posedge CLK)\n  begin\n   out5v_nenable = tmr4ovfl | nsleep;\n  end\nendmodule\n"},{"type":1,"id":"a3a430f2-5f0d-4a0d-9295-1bebb2da0fa8","name":"xor_result","text":"module xor_result(b7,b6,b5,b4,b3,b2,b1,b0,allzero);\n input b7,b6,b5,b4,b3,b2,b1,b0;\n output allzero;\n\n wire [7:0] byte_result;\n assign byte_result = {b7,b6,b5,b4,b3,b2,b1,b0};\n assign allzero = |byte_result;\nendmodule\n"},{"type":0,"id":"9ef149bf-2feb-4195-a853-b1bbfaea254d","name":"main","data":{"class":"GraphLinksModel","linkKeyProperty":"key","linkFromPortIdProperty":"fromPort","linkToPortIdProperty":"toPort","nodeDataArray":[{"category":"inputport","portname":"CLBSWIN1","size":"130 20","key":-30,"loc":"-10 -850","settings":{}},{"category":"inputport","portname":"CLBSWIN2","size":"130 20","key":-31,"loc":"-10 -900","settings":{}},{"category":"inputport","portname":"CLBSWI