{"type":"Microchip CLB Synthesizer Design","version":"2.0","name":"mult3x3u_main","projectId":"580b2d45-529c-479a-956a-cae991c7d09c","creationDate":"2026-01-27T16:49:11.990Z","backendversion":"https://logic.microchip.com/","device":"PIC16F13145","documentModels":[{"type":1,"id":"d01b5a17-8613-4317-a889-49d4fd3d60cb","name":"mult3x3u","text":"module mult3x3u(a2,a1,a0,b2,b1,b0,y5,y4,y3,y2,y1,y0);\n\n    input a2,a1,a0,b2,b1,b0;\n    output y5,y4,y3,y2,y1,y0;\n\n    logic [2:0] a,b;\n    logic [5:0] y;\n\n    assign a = {a2, a1, a0};\n    assign b = {b2, b1, b0};\n    assign y = $unsigned(a) * $unsigned(b);\n    assign y5 = y[5];\n    assign y4 = y[4];\n    assign y3 = y[3];\n    assign y2 = y[2];\n    assign y1 = y[1];\n    assign y0 = y[0];\nendmodule\n"},{"type":1,"id":"0da42163-e114-487c-8b2f-c7806c221077","name":"mult3x3l","text":"module mult3x3l(zero,a0,b0,y1,y0);\n    input zero,a0,b0;\n    output y1,y0;\n\n    assign y1 = zero;\n    assign y0 = a0 & b0; \nendmodule\n"},{"type":0,"id":"6260d886-fcf1-44a4-b0b3-ed8b4e271895","name":"main","data":{"class":"GraphLinksModel","linkKeyProperty":"key","linkFromPortIdProperty":"fromPort","linkToPortIdProperty":"toPort","nodeDataArray":[{"category":"inputport","portname":"CLBSWIN7","size":"130 20","loc":"-260 -290","key":3,"settings":{}},{"category":"inputport","portname":"CLBSWIN6","size":"130 20","loc":"-260 -270","key":4,"settings":{}},{"category":"inputport","portname":"CLBSWIN5","size":"130 20","loc":"-260 -250","key":5,"settings":{}},{"category":"inputport","portname":"CLBSWIN4","size":"130 20","loc":"-260 -230","key":6,"settings":{}},{"category":"inputport","portname":"CLBSWIN3","size":"130 20","loc":"-260 -210","key":7,"settings":{}},{"category":"inputport","portname":"CLBSWIN2","size":"130 20","loc":"-260 -190","key":8,"settings":{}},{"key":-9,"category":"sheet","refdes":"","loc":"-140 -320","name":"mult3x3u","inputs":[{"portId":"a2","label":"a2","settings":{}},{"portId":"a1","label":"a1","settings":{}},{"portId"